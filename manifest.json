{
  "manifest_version": 3,
  "name": "Scroll to PDF",
  "version": "1.0.0",
  "description": "Auto-scrolls pages, captures full content natively, and generates high-quality PDFs.",
  "permissions": [
    "activeTab",
    "scripting",
    "offscreen",
    "downloads"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
